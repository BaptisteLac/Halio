# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PostHog analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Web Push (VAPID) — générer avec : npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY et VAPID_PRIVATE_KEY doivent aussi être ajoutés
# comme secrets dans le Dashboard Supabase (Edge Functions > Secrets)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@halioapp.com
